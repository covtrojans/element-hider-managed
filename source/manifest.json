{
	"manifest_version": 3,
	"name": "Element Hider",
	"version": "1.0.0",
	"description": "Hides specific elements on webpages",
	"update_url": "https://raw.githubusercontent.com/covtrojans/element-hider-managed/refs/heads/main/updates.xml",
	"icons": {
		"16": "porygon-normal.png",
		"32": "porygon-normal.png",
		"48": "porygon-normal.png",
		"128": "porygon-normal.png"
	},
	"action": {
		"default_popup": "popup.html"
	},
	"storage": {
		"managed_schema": "schema.json"
	},
	"permissions": [
		"storage",
		"scripting"
	],
	"host_permissions": ["<all_urls>"], 
	"background": {
		"service_worker": "background.js"
	}
}